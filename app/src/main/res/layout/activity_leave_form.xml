<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF"
    tools:context=".LeaveFormActivity"
    tools:ignore="ExtraText"
    android:fitsSystemWindows="true">

    <!-- Fixed Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        android:layout_gravity="top"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#F8F9FF"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="#2B2BE8"
            app:title="Permohonan Izin/Sakit"
            app:titleCentered="true"
            app:titleTextAppearance="@style/ToolbarTitle"
            app:titleTextColor="#2B2BE8" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottomAppBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp">

            <!-- Leave Type Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                android:layout_marginTop="4dp"
                app:cardElevation="0dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dmsans_medium"
                        android:text="Jenis Permohonan"
                        android:textColor="#1A1A1A"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/leaveTypeChipGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:selectionRequired="true"
                        app:singleSelection="true"
                        tools:ignore="TouchTargetSizeCheck">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSick"
                            style="@style/Widget.EPresence.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="Sakit"
                            android:textColor="#1A1A1A"
                            android:textSize="12sp"
                            app:checkedIconTint="#2B2BE8"
                            app:chipBackgroundColor="@color/chip_background_color"
                            app:chipStrokeColor="#E0E0E0"
                            app:chipStrokeWidth="1dp"
                            tools:ignore="HardcodedText,TouchTargetSizeCheck" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPermission"
                            style="@style/Widget.EPresence.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:text="Izin"
                            android:textColor="#1A1A1A"
                            android:textSize="12sp"
                            app:checkedIconTint="#2B2BE8"
                            app:chipBackgroundColor="@color/chip_background_color"
                            app:chipStrokeColor="#E0E0E0"
                            app:chipStrokeWidth="1dp"
                            tools:ignore="HardcodedText,TouchTargetSizeCheck" />
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Date Range Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dmsans_medium"
                        android:text="Periode Permohonan"
                        android:textColor="#1A1A1A"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/dmsans_regular"
                                android:text="Tanggal Mulai"
                                android:textColor="#757575"
                                android:textSize="12sp"
                                tools:ignore="HardcodedText" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutStartDate"
                                style="@style/Widget.EPresence.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxStrokeColor="#2B2BE8"
                                app:endIconDrawable="@drawable/calendar"
                                app:endIconMode="custom"
                                app:endIconTint="@color/custom_blue"
                                app:hintEnabled="false">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/startDate"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:focusable="false"
                                    android:fontFamily="@font/dmsans_regular"
                                    android:hint="Pilih tanggal"
                                    android:inputType="none"
                                    android:paddingVertical="12dp"
                                    android:textColor="#1A1A1A"
                                    android:textColorHint="#BDBDBD"
                                    android:textSize="14sp"
                                    tools:ignore="HardcodedText,DuplicateSpeakableTextCheck,TextContrastCheck,TouchTargetSizeCheck" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/dmsans_regular"
                                android:text="Tanggal Akhir"
                                android:textColor="#757575"
                                android:textSize="12sp"
                                tools:ignore="HardcodedText" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutEndDate"
                                style="@style/Widget.EPresence.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxStrokeColor="@color/custom_blue"
                                app:endIconDrawable="@drawable/calendar"
                                app:endIconMode="custom"
                                app:endIconTint="@color/custom_blue"
                                app:hintEnabled="false"
                                tools:ignore="ExtraText">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/endDate"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:focusable="false"
                                    android:fontFamily="@font/dmsans_regular"
                                    android:hint="Pilih tanggal"
                                    android:inputType="none"
                                    android:paddingVertical="12dp"
                                    android:textColor="#1A1A1A"
                                    android:textColorHint="#BDBDBD"
                                    android:textSize="14sp"
                                    tools:ignore="HardcodedText,TextContrastCheck,TouchTargetSizeCheck" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Duration Summary -->
                    <TextView
                        android:id="@+id/durationSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/rounded_pill_background"
                        android:fontFamily="@font/dmsans_medium"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="Durasi: 0 hari"
                        android:textColor="#2B2BE8"
                        android:textSize="12sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Reason Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dmsans_medium"
                        android:text="Keterangan / Alasan"
                        android:textColor="#1A1A1A"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutReason"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#2B2BE8"
                        app:counterEnabled="true"
                        app:counterMaxLength="500"
                        app:counterTextColor="@color/grey_600"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/reason"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dmsans_regular"
                            android:gravity="top"
                            android:hint="Masukkan alasan izin/sakit"
                            android:inputType="textMultiLine"
                            android:minLines="4"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BDBDBD"
                            android:textSize="14sp"
                            tools:ignore="HardcodedText,TextContrastCheck" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Attachments Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/dmsans_medium"
                            android:text="Lampiran"
                            android:textColor="#1A1A1A"
                            android:textSize="16sp"
                            tools:ignore="HardcodedText" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddAttachment"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dmsans_medium"
                            android:textAllCaps="false"
                            android:textColor="#2B2BE8"
                            app:icon="@drawable/plus"
                            app:iconGravity="textStart"
                            app:iconTint="#2B2BE8"
                            tools:ignore="HardcodedText,SpeakableTextPresentCheck" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dmsans_regular"
                        android:text="Format: PDF, JPG, PNG, JPEG (Maks. 10MiB)"
                        android:textColor="#757575"
                        android:textSize="12sp"
                        tools:ignore="HardcodedText,TextContrastCheck" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/attachmentRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false"
                        android:visibility="visible"
                        tools:itemCount="2"
                        tools:listitem="@layout/item_attachment" />

                    <LinearLayout
                        android:id="@+id/emptyAttachmentView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:ignore="UseCompoundDrawables">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ban"
                            app:tint="#BDBDBD"
                            tools:ignore="ContentDescription" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/dmsans_regular"
                            android:text="Belum ada lampiran"
                            android:textColor="#757575"
                            android:textSize="14sp"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Fixed Bottom Button -->
    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottomAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:backgroundTint="#FFFFFF"
        app:contentInsetStart="0dp"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:ignore="BottomAppBar,ExtraText">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:fontFamily="@font/dmsans_medium"
                android:text="Kirim Permohonan"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:backgroundTint="#2B2BE8"
                app:cornerRadius="28dp"
                app:elevation="0dp"
                app:icon="@drawable/send"
                app:iconGravity="textEnd"
                app:iconPadding="15dp"
                app:iconTint="#FFFFFF"
                tools:ignore="HardcodedText" />
        </FrameLayout>
    </com.google.android.material.bottomappbar.BottomAppBar>
</androidx.constraintlayout.widget.ConstraintLayout>